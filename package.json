{
  "name": "@arts-n-crafts/ts",
  "version": "3.19.0",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arts-n-crafts/typescript.git"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@release-it/bumper": "^7.0.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.12",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "changelogen": "^0.6.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "oxide.ts": "^1.1.0",
    "release-it": "^20.0.0",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./packages/v3/dist/index.d.ts",
        "default": "./packages/v3/dist/index.js"
      },
      "require": {
        "types": "./packages/v3/dist/index.d.cts",
        "default": "./packages/v3/dist/index.cjs"
      }
    },
    "./v3": {
      "import": {
        "types": "./packages/v3/dist/index.d.ts",
        "default": "./packages/v3/dist/index.js"
      },
      "require": {
        "types": "./packages/v3/dist/index.d.cts",
        "default": "./packages/v3/dist/index.cjs"
      }
    },
    "./v4": {
      "import": {
        "types": "./packages/v4/dist/index.d.ts",
        "default": "./packages/v4/dist/index.js"
      },
      "require": {
        "types": "./packages/v4/dist/index.d.cts",
        "default": "./packages/v4/dist/index.cjs"
      }
    },
    "./v5": {
      "import": {
        "types": "./packages/v5/dist/index.d.ts",
        "default": "./packages/v5/dist/index.js"
      },
      "require": {
        "types": "./packages/v5/dist/index.d.cts",
        "default": "./packages/v5/dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "packages/v3/dist",
    "packages/v4/dist",
    "packages/v5/dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "private": false,
  "scripts": {
    "prepare": "husky",
    "commit": "cz",
    "release": "release-it && npm publish --access=public",
    "build": "bun run --workspaces build",
    "coverage": "bun run --workspaces coverage",
    "lint": "bun run --workspaces lint",
    "lint:fix": "bun run --workspaces lint:fix",
    "typecheck": "bun run --workspaces typecheck",
    "check-exports": "attw --pack . --profile node16"
  },
  "type": "module"
}
